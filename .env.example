# Copy this file to .env.local and fill in your key.

# Get a free API key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Default model. gemini-2.5-flash-lite has a generous free-tier quota
# (~1,500 req/day); gemini-2.5-flash is higher quality but ~20 req/day on free tier.
GEMINI_MODEL=gemini-2.5-flash-lite

# --- Supabase (OPTIONAL) ---
# Leave blank to use the local disk/localStorage stores (zero setup).
# Set both to move brand memory to Postgres + pgvector (required for serverless
# persistence). See SUPABASE_SETUP.md. The service-role key is server-only —
# never expose it to the browser.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
